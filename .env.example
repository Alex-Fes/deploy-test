# ================================================================
# .env.example — шаблон для .env.stage и .env.prod
#
# На VPS создайте два файла в корне каждого клона репозитория:
#   .env.stage  — для stage окружения (ветка dev)
#   .env.prod   — для prod окружения (ветка main)
#
# Оба файла добавлены в .gitignore и не попадают в репозиторий.
# Порты (PORT, API_PORT) PM2 проставляет через ecosystem.config.js
# автоматически; указанные здесь значения — для локальной разработки.
# ================================================================

NODE_ENV=production

# ── Next.js ──────────────────────────────────────────────────────
# Stage: PORT = 3000+N, Prod: PORT = 4000+N (задаётся в ecosystem.config.js)
PORT=3000
HOSTNAME=127.0.0.1

# URL, по которому браузер обращается к API (совпадает с Nginx location /api/)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── NestJS ───────────────────────────────────────────────────────
# Stage: API_PORT = 3100+N, Prod: API_PORT = 4100+N (задаётся в ecosystem.config.js)
API_PORT=3001

# Разрешённый origin для CORS
WEB_ORIGIN=http://localhost:3000

# ── База данных (PostgreSQL) ──────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=landing_user
DATABASE_PASSWORD=landing_password
DATABASE_NAME=deploy-test

# ── SMTP (отправка почты) ─────────────────────────────────────────
SMTP_HOST=smtp.your-mail-provider.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailer@example.com
SMTP_PASS=change-me
MAIL_FROM=hello@example.com
MAIL_TO=admin@example.com
