{
  "name": "deploy-test",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.3",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "dev": "turbo dev --filter=@repo/web --filter=@repo/api",
    "dev:local": "npm run db:up && npm run dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@nestjs/cli": "latest",
    "turbo": "latest",
    "typescript": "latest"
  }
}
